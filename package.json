{
  "name": "calculator-app",
  "version": "1.0.0",
  "description": "Desktop calculator for Windows",
  "main": "dist/infrastructure/main.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); fs.copyFileSync('src/presentation/index.html','dist/presentation/index.html'); fs.copyFileSync('src/presentation/styles.css','dist/presentation/styles.css')\"",
    "start": "npm run build && electron dist/infrastructure/main.js",
    "test": "npm run build && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.17.0",
    "electron": "^33.0.0",
    "playwright-core": "^1.61.1",
    "typescript": "^5.6.0"
  }
}
